<IfModule mod_rewrite.c>
    RewriteEngine On

    # Servir archivos reales directamente (CSS, JS, imágenes, etc.)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Servir directorios reales directamente
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirigir todo lo demás al entry point
    RewriteRule ^ index.php [QSA,L]
</IfModule>
